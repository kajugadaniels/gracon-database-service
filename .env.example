# Database owner connection.
# This URL is only for api/database migration and database-owned seed commands.
# Use a dedicated Postgres role with DDL permissions.
DATABASE_MIGRATION_URL=postgresql://gracon_migrator:password@host/db?sslmode=verify-full

# First SUPER_ADMIN seed.
# Used by: npm run db:seed
# Remove SUPER_ADMIN_PASSWORD from real environment files after production seed.
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_EMAIL=superadmin@yourplatform.com
SUPER_ADMIN_PASSWORD=YourStr0ng!Password

