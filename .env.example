# database .env.example - managed by Milestone 10 secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# Database owner connection
# Only api/database may use migration-capable credentials.
# Runtime API services must use their own least-privilege DATABASE_URL.
DATABASE_MIGRATION_URL=postgresql://gracon_migrator:password@host/db?sslmode=verify-full
EXPECTED_MIGRATION_DATABASE_USER=gracon_migrator

# First SUPER_ADMIN seed
# Used only by npm run db:seed in api/database.
# Generate SUPER_ADMIN_PASSWORD with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Remove SUPER_ADMIN_PASSWORD from production secrets after the first seed succeeds.
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_EMAIL=superadmin@yourplatform.com
SUPER_ADMIN_PASSWORD=generate_a_strong_seed_password
